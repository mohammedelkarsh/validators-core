{
    "name": "validators/core",
    "description": "Shared validation primitives for country-specific validator packages.",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Validators\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Validators\\Core\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
